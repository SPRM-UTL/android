    <style name="Widget.Custom.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="boxStrokeErrorColor">@color/red</item>
        <item name="errorTextColor">@color/red</item>
        <item name="errorTextAppearance">@style/ErrorTextAppearance</item>
        <item name="errorIconTint">@color/red</item>
        <item name="hintTextColor">@color/teal_primary</item>
        <item name="android:textColorHint">@color/text_grey</item>
        <item name="startIconTint">@color/teal_primary</item>
        <item name="endIconTint">@color/teal_primary</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
        <item name="errorEnabled">true</item>
        <item name="helperTextTextColor">@color/red</item>
    </style>

    <style name="Widget.Custom.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/teal_primary</item>
        <item name="android:textColorHint">@color/text_grey</item>
        <item name="startIconTint">@color/teal_primary</item>
        <item name="endIconTint">@color/teal_primary</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
    </style>

    <style name="Widget.Custom.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#1A1A1A</item>
        <item name="android:textCursorDrawable">@drawable/cursor_custom</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="ErrorTextAppearance" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/red</item>
    </style>

    <style name="Theme.ExposedDropdownMenuOverlay" parent="">
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>

    <style name="TextAppearance.DropdownItem" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/teal_primary</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="elevationOverlayColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="materialAlertDialogTheme">@style/CustomAlertDialogStyle</item>
    </style>

    <style name="CustomAlertDialogStyle" parent="MaterialAlertDialog.Material3">
        <item name="android:background">@android:color/white</item>
        <item name="backgroundTint">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>

        <item name="android:textColorPrimary">#073F4C</item>
        <item name="android:textColorSecondary">#6F7E8E</item>

        <item name="shapeAppearance">@style/ShapeAppearance.Material3.MediumComponent</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.MediumComponent</item>

        <item name="materialAlertDialogTitleTextStyle">@style/CustomAlertDialogTitleText</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CustomAlertDialogBodyText</item>

        <item name="buttonBarPositiveButtonStyle">@style/DialogBotonEliminar</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogBotonCancelar</item>
    </style>

    <style name="CustomAlertDialogTitleText" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">#073F4C</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="CustomAlertDialogBodyText" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">#6F7E8E</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="DialogBotonEliminar" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/red</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogBotonCancelar" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/btn_dialog_selector</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="Theme.UCrop.Custom" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Colores personalizados -->
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryDark">@color/teal_medium</item>
        <item name="colorAccent">@color/teal_primary</item>
        
        <!-- Fondo -->
        <item name="android:windowBackground">@color/background</item>
        
        <!-- Para edge-to-edge en Android 10+ -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        
        <!-- Force dark mode off para evitar problemas con UCrop -->
        <item name="android:forceDarkAllowed">false</item>
        
        <!-- Hacer el toolbar transparente -->
        <item name="android:actionBarStyle">@style/Widget.UCrop.ActionBar.Transparent</item>
    </style>

    <style name="Widget.UCrop.ActionBar.Transparent" parent="Widget.AppCompat.Light.ActionBar.Solid.Inverse">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:elevation">0dp</item>
    </style>

</resources>
</file>

