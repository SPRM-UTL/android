<file path="app/src/main/res/layout/dialog_connecting.xml">
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressConectando"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminate="true"
            app:indicatorColor="@color/teal_primary"
            app:trackColor="#1A009688"
            app:trackThickness="5dp" />

        <TextView
            android:id="@+id/tvConectandoNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Conectando..."
            android:textColor="#1A1A1A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConectandoSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Estableciendo vínculo Bluetooth"
            android:textColor="#9E9E9E"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelConnecting"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="Cancelar Conexión"
            android:textColor="@color/teal_primary"
            app:strokeColor="@color/teal_primary"
            app:cornerRadius="16dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
</file>

<file path="app/src/main/res/layout/dialog_device_form.xml">
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <!-- ScrollView externo: garantiza que los botones siempre sean accesibles -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="560dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Título -->
            <TextView
                android:id="@+id/tvDialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Añadir Dispositivo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#17252A"
                android:layout_marginBottom="20dp"/>

            <!-- Nombre del dispositivo -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDeviceName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre del Dispositivo"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tipo de dispositivo (dropdown predefinido) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etDeviceType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tipo de Dispositivo"
                    android:inputType="none"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Casa (dropdown) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etCasa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Casa"
                    android:inputType="none"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Habitación (dropdown) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etHabitacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Habitación"
                    android:inputType="none"
                    android:textColor="#000000" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Sección Bluetooth -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vincular por Bluetooth"
                android:textColor="#17252A"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Botón escanear -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanBluetooth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Escanear dispositivos"
                android:textAllCaps="false"
                app:backgroundTint="@color/teal_primary"
                app:cornerRadius="12dp"
                app:icon="@drawable/bluetooth"
                app:iconGravity="textStart"
                android:layout_marginBottom="12dp"/>

            <!-- ProgressBar de escaneo -->
            <LinearLayout
                android:id="@+id/layoutScanProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="10dp"
                    style="?android:attr/progressBarStyleSmall"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buscando dispositivos..."
                    android:textColor="#666666"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Lista de dispositivos BT: altura FIJA para no desplazar los botones -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBluetoothDevices"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:nestedScrollingEnabled="true"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- Dispositivo BT seleccionado — Nombre (solo lectura) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutBtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre Bluetooth"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dispositivo BT seleccionado — MAC (solo lectura) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutBtMac"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/teal_primary"
                app:hintTextColor="@color/teal_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBtMac"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dirección MAC"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:textColor="#000000"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botones Cancelar / Guardar — siempre visibles al hacer scroll -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCancel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Cancelar"
                    android:textColor="#6F7EA8" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardar"
                    android:backgroundTint="@color/teal_primary" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</com.google.android.material.card.MaterialCardView>
</file>

<file path="app/src/main/res/layout/dialog_esp_vinculado.xml">
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:orientation="vertical"
    android:padding="24dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#BDBDBD" />

    <!-- Ícono de éxito -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:src="@drawable/wifi"
        app:tint="@color/teal_primary" />

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="¡ESP32 Conectado!"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="El dispositivo se conectó a la red WiFi correctamente."
        android:textColor="#8A8A8A"
        android:textSize="13sp" />

    <!-- Chip de IP y MAC -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#F0FAF9"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/teal_primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="10dp"
                android:src="@drawable/wifi"
                app:tint="@color/teal_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dirección IP"
                    android:textColor="#8A8A8A"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvEspIp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/teal_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAC BLE"
                    android:textColor="#8A8A8A"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvEspMac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#444444"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Selección de aparato -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"
        android:text="Asociar a un aparato"
        android:textColor="#444444"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Selecciona el aparato que utilizará este ESP32 como controlador de red."
        android:textColor="#8A8A8A"
        android:textSize="12sp" />

    <!-- Spinner: aparatos existentes -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutSpinnerAparato"
        style="@style/Widget.Custom.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Seleccionar aparato"
        app:startIconDrawable="@drawable/lamp_floor"
        app:startIconTint="@color/teal_primary">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/spinnerAparato"
            style="@style/Widget.Custom.TextInputEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="#1A1A1A" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botones -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarConfig"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Guardar y Continuar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/teal_primary"
        app:cornerRadius="14dp"
        app:icon="@drawable/wifi"
        app:iconGravity="textStart"
        app:iconTint="@color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaltarConfig"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Saltar por ahora"
        android:textColor="#BDBDBD"
        android:textSize="13sp" />

</LinearLayout>
</file>

