        app:layout_constraintTop_toBottomOf="@id/cardBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:strokeColor="#E8EFF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consumo de Energía"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Corriente"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvCorriente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 A"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Potencia"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvPotencia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 W"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Energía"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvEnergia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 Wh"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
