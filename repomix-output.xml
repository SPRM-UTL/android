    <footer class="border-t border-cafe-light bg-white py-6 text-center text-sm text-muted font-body">
        <p>&copy; 2026 SPRM-UTL &mdash; Compilado automáticamente con Docker &amp; Render.</p>
    </footer>

    <script>
        async function loadVersions() {
            const container = document.getElementById('versions-container');
            try {
                const response = await fetch('./downloads.json');
                const files = await response.json();

                if (files.length === 0) {
                    container.innerHTML = `
                        <div class="text-muted py-10 text-center bg-white border border-cafe-light rounded-xl font-body">
                            No hay compilaciones anteriores registradas en este despliegue.
                        </div>`;
                    return;
                }

                container.innerHTML = '';
                files.slice().reverse().forEach(function(filename) {
                    var label = filename;
                    // Nuevo formato: app-v1.0_20260620_123456.apk
                    var match = filename.match(/app-v([^_]+)_(\d{4})(\d{2})(\d{2})_(\d{2})(\d{2})(\d{2})\.apk/);
                    if (match) {
                        label = 'v' + match[1] + ' \u2014 ' + match[4] + '/' + match[3] + '/' + match[2] + ' ' + match[5] + ':' + match[6] + ':' + match[7];
                    } else {
                        // Formato legacy: app-release_YYYYMMDD_HHMMSS.apk
                        var m2 = filename.match(/_(\d{4})(\d{2})(\d{2})_(\d{2})(\d{2})(\d{2})/);
                        if (m2) {
                            label = 'Compilaci\u00f3n ' + m2[3] + '/' + m2[2] + '/' + m2[1] + ' \u2014 ' + m2[4] + ':' + m2[5] + ':' + m2[6];
                        }
                    }

                    var card = document.createElement('div');
                    card.className = 'flex items-center justify-between p-4 bg-white border-[1.5px] border-cafe-light rounded-xl hover:border-cafe-primary/60 hover:shadow-[0_4px_14px_rgba(43,191,170,0.12)] transition-all duration-200';
                    card.innerHTML =
                        '<div class="flex items-center gap-3">' +
                            '<div class="w-9 h-9 flex items-center justify-center bg-cafe-light rounded-lg text-cafe-primary flex-shrink-0">' +
                                '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                                    '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>' +
                                    '<path d="M14 2v4a2 2 0 0 0 2 2h4"/>' +
                                    '<path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>' +
                                '</svg>' +
                            '</div>' +
                            '<div>' +
                                '<p class="font-semibold text-cafe-dark font-heading text-sm">' + label + '</p>' +
                                '<p class="text-xs text-muted font-data mt-0.5">' + filename + '</p>' +
                            '</div>' +
                        '</div>' +
                        '<a href="./downloads/' + filename + '" ' +
                           'class="inline-flex items-center gap-1.5 bg-cafe-primary hover:bg-cafe-dark text-white font-body text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200 flex-shrink-0">' +
                            '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">' +
                                '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>' +
                                '<polyline points="7 10 12 15 17 10"/>' +
                                '<line x1="12" y1="15" x2="12" y2="3"/>' +
                            '</svg>' +
                            'Descargar' +
                        '</a>';
                    container.appendChild(card);
                });

            } catch (error) {
                console.error('Error cargando el historial:', error);
                container.innerHTML =
                    '<div class="text-red-600 py-8 text-center bg-red-50 border border-red-100 rounded-xl font-body flex items-center justify-center gap-2">' +
                        '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                            '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>' +
                            '<line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>' +
                        '</svg>' +
                        'Error al cargar el historial de versiones.' +
                    '</div>';
            }
        }

        document.addEventListener('DOMContentLoaded', loadVersions);
    </script>
</body>
</html>
