<file path="app/src/main/res/layout/dialog_config_device.xml">
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Configurar dispositivo"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Estás a punto de configurar:"
            android:textColor="#8A8A8A"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDeviceTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="Nombre del Hardware"
            android:textColor="@color/teal_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- NUEVO: ícono del tipo seleccionado y bluetooth si lo requiere -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivTipoIcono"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:visibility="gone"
                app:tint="@color/teal_primary" />

            <ImageView
                android:id="@+id/ivBluetoothRequired"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_link"
                android:visibility="gone"
                app:tint="@color/teal_primary" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNombre"
            style="@style/Widget.Custom.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Nombre del dispositivo"
            app:startIconDrawable="@drawable/pencil"
            app:startIconTint="@color/teal_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDeviceName"
                style="@style/Widget.Custom.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#1A1A1A" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutTipo"
            style="@style/Widget.Custom.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Selecciona tipo de dispositivo"
            app:startIconTint="@color/teal_primary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etDeviceType"
                style="@style/Widget.Custom.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="#1A1A1A" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutCasa"
            style="@style/Widget.Custom.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Selecciona Casa"
            app:startIconTint="@color/teal_primary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etCasa"
                style="@style/Widget.Custom.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="#1A1A1A" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutHabitacion"
            style="@style/Widget.Custom.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Selecciona Habitación"
            app:startIconTint="@color/teal_primary">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etHabitacion"
                style="@style/Widget.Custom.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="#1A1A1A" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="54dp"
                android:layout_marginEnd="12dp"
                android:text="CANCELAR"
                android:textColor="@color/teal_primary"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="140dp"
                android:layout_height="54dp"
                android:text="Configurar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/teal_primary"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteDialog"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Eliminar Dispositivo"
            android:textColor="@color/red"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
</file>

