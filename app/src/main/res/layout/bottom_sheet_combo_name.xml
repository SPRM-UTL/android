<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre del Combo"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#073F4C"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asigna un nombre fácil de recordar para este combo."
        android:textSize="14sp"
        android:textColor="#6F7E8E"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etBottomSheetComboName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. Apagar luces de noche"
        android:textColor="#073F4C"
        android:padding="16dp"
        android:background="#F0F3F7"
        android:inputType="textCapWords"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSaveComboName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirmar"
        android:textColor="@color/white"
        android:backgroundTint="@color/teal_primary"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
