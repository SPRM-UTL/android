<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <View
            android:id="@+id/circleBluetooth"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:background="@android:drawable/presence_online"
            android:backgroundTint="#0B847E" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_centerInParent="true"
            android:layout_alignStart="@id/circleBluetooth"
            android:layout_alignEnd="@id/circleBluetooth"
            android:layout_alignTop="@id/circleBluetooth"
            android:layout_alignBottom="@id/circleBluetooth"
            android:src="@drawable/bluetooth"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/circleBluetooth"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreDispositivoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dispositivo Desconocido"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMacDispositivoItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="D4:AB:CD:61:FF:A0"
                android:textColor="#777777"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_manordomo_sin_fondo"
            app:tint="#444444" />
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>