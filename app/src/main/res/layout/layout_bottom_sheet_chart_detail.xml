<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_white_rounded">

    <TextView
        android:id="@+id/tvSheetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Período"
        android:textColor="#212121"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Energía -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Energía consumida"
            android:textColor="#757575"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/tvSheetEnergy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 kWh"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Potencia Promedio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Potencia promedio"
            android:textColor="#757575"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/tvSheetPower"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 W"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Costo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Costo estimado"
            android:textColor="#757575"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/tvSheetCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0.00 MXN"
            android:textColor="@color/teal_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSheetClose"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Cerrar"
        android:textColor="@color/teal_primary" />

</LinearLayout>
