<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_manordomo_sin_fondo"
            app:tint="@color/teal_primary"
            android:alpha="0.85"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajustar Tiempo de Sostenimiento"
            android:textColor="#073F4C"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura cuántos cuadros consecutivos de video debe mantenerse la pose antes de ser validada."
            android:textColor="#6F7E8E"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="20dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Velocidad de Reacción"
            android:textColor="#6F7E8E"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvFramesValueInner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 cuadros"
                    android:textColor="@color/teal_primary"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <SeekBar
                    android:id="@+id/seekBarFramesInner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="27"
                    android:progress="12"
                    android:thumbTint="@color/teal_primary"
                    android:progressTint="@color/teal_primary"
                    android:progressBackgroundTint="#A0AAB5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menos cuadros = Respuesta veloz pero propenso a falsos positivos."
                    android:textColor="#6F7E8E"
                    android:textSize="11sp"
                    android:layout_marginTop="12dp"
                    android:textAlignment="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
