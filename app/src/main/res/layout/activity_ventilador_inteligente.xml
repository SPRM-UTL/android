<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainVentilador"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FFFF">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/teal_primary"
        app:cardCornerRadius="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnBackControls"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/arrow_left"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvControlDeviceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Ventilador Inteligente"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginEnd="48dp"
                app:layout_constraintStart_toEndOf="@id/btnBackControls"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:strokeColor="#E8EFF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consumo de Energía"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Corriente"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvCorriente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 A"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Potencia"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvPotencia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 W"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Energía"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tvEnergia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00 Wh"
                                android:textStyle="bold"
                                android:textColor="@color/teal_primary"
                                android:textSize="18sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:strokeColor="#E8EFF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Velocidades"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo una velocidad activa a la vez"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardVelocidad1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#EAEAEA"
                            app:cardBackgroundColor="#F9FBFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/iconVelocidad1"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/wind"
                                    android:padding="6dp"
                                    app:tint="@color/teal_primary" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:id="@+id/tvLabelVelocidad1"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Velocidad 1"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black" />

                                    <TextView
                                        android:id="@+id/tvStatusVelocidad1"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Apagado"
                                        android:textSize="13sp"
                                        android:textColor="#888888"
                                        android:layout_marginTop="2dp" />
                                </LinearLayout>

                                <com.google.android.material.switchmaterial.SwitchMaterial
                                    android:id="@+id/switchVelocidad1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:useMaterialThemeColors="true" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardVelocidad2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#EAEAEA"
                            app:cardBackgroundColor="#F9FBFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/iconVelocidad2"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/wind"
                                    android:padding="6dp"
                                    app:tint="@color/teal_primary" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:id="@+id/tvLabelVelocidad2"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Velocidad 2"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black" />

                                    <TextView
                                        android:id="@+id/tvStatusVelocidad2"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Apagado"
                                        android:textSize="13sp"
                                        android:textColor="#888888"
                                        android:layout_marginTop="2dp" />
                                </LinearLayout>

                                <com.google.android.material.switchmaterial.SwitchMaterial
                                    android:id="@+id/switchVelocidad2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:useMaterialThemeColors="true" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardVelocidad3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#EAEAEA"
                            app:cardBackgroundColor="#F9FBFD">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:id="@+id/iconVelocidad3"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/wind"
                                    android:padding="6dp"
                                    app:tint="@color/teal_primary" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:id="@+id/tvLabelVelocidad3"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Velocidad 3"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black" />

                                    <TextView
                                        android:id="@+id/tvStatusVelocidad3"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Apagado"
                                        android:textSize="13sp"
                                        android:textColor="#888888"
                                        android:layout_marginTop="2dp" />
                                </LinearLayout>

                                <com.google.android.material.switchmaterial.SwitchMaterial
                                    android:id="@+id/switchVelocidad3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:useMaterialThemeColors="true" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
