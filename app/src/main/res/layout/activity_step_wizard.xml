<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarWizard"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1F1B24"
        app:title="Paso 1: Seleccionar Gesto"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- WIZARD STEP 1: POSE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutStep1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarWizard"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPoses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp"/>
            
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- WIZARD STEP 2: HAND -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutStep2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarWizard"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvHandPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="¿Qué mano debe hacer el gesto?"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnHandAny"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="16dp"
            android:text="Cualquier Mano"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/tvHandPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnHandLeft"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="16dp"
            android:text="Mano Izquierda"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/btnHandAny"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnHandRight"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_margin="16dp"
            android:text="Mano Derecha"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/btnHandLeft"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- WIZARD STEP 3: FRAMES -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutStep3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarWizard"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFramesPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Selecciona la Velocidad de Reacción"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
            
        <TextView
            android:id="@+id/tvFramesDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Cuántos cuadros consecutivos debes mantener el gesto para que se valide. (Menos cuadros = Más rápido pero propenso a errores)"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvFramesPrompt"/>

        <TextView
            android:id="@+id/tvFramesValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="15 frames"
            android:textColor="#03DAC5"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvFramesDesc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <SeekBar
            android:id="@+id/seekBarFrames"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:max="25"
            android:progress="10"
            app:layout_constraintTop_toBottomOf="@id/tvFramesValue" />

        <Button
            android:id="@+id/btnFinishWizard"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="CONFIRMAR Y AÑADIR"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#BB86FC"
            android:textColor="#000000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
