<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!--
        Safe area: el CoordinatorLayout ocupa toda la pantalla (edge-to-edge).
        El padding dinámico (status bar + nav bar) se aplica desde el Kotlin
        con ViewCompat.setOnApplyWindowInsetsListener sobre este root.
    -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="165dp"
            android:background="@color/teal_primary"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardSuperior"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvWizardTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Preparando el Sistema"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStepCounter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="12dp"
                android:text="Paso 1 de 5"
                android:textColor="#AEE2DE"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvWizardTitle" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Barra de progreso de pasos -->
        <LinearLayout
            android:id="@+id/stepDotsContainer"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:weightSum="5"
            app:layout_constraintTop_toBottomOf="@id/headerBackground">

            <View android:id="@+id/dot1"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/step_dot_inactive" />
            <View android:id="@+id/dot2"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/step_dot_inactive" />
            <View android:id="@+id/dot3"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/step_dot_inactive" />
            <View android:id="@+id/dot4"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/step_dot_inactive" />
            <View android:id="@+id/dot5"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:background="@drawable/step_dot_inactive" />
        </LinearLayout>

        <!-- ── TARJETA DEL PERMISO ACTUAL ────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPermiso"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/stepDotsContainer"
            app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <!-- Ícono SVG Lucide (se cambia por código) -->
                <ImageView
                    android:id="@+id/ivPermisoIcon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/camera"
                    app:tint="@color/teal_primary"
                    android:layout_marginBottom="24dp" />

                <!-- Nombre del permiso -->
                <TextView
                    android:id="@+id/tvPermisoNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cámara"
                    android:textColor="#17252A"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- Descripción -->
                <TextView
                    android:id="@+id/tvPermisoDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Necesaria para capturar imágenes."
                    android:textColor="#6F7EA8"
                    android:textSize="15sp"
                    android:textAlignment="center"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp" />

                <!-- Ícono de estado (check / x) -->
                <ImageView
                    android:id="@+id/ivEstado"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/circle_x"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp" />

                <!-- Botón de acción del paso actual -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccion"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Conceder permiso"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="@color/teal_primary"
                    android:textColor="@color/white" />

                <!-- Etiqueta cuando ya está concedido -->
                <TextView
                    android:id="@+id/tvYaConcedido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Permiso concedido"
                    android:textColor="@color/teal_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── BOTONES DE NAVEGACIÓN ──────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnterior"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Anterior"
                android:textColor="@color/teal_primary"
                app:strokeColor="@color/teal_primary"
                app:cornerRadius="12dp"
                android:visibility="invisible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSiguiente"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Siguiente"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/teal_primary"
                android:textColor="@color/white" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>