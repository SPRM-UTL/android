<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_rounded"
    android:clipToOutline="true">

    <!-- CABECERA FIJA -->
    <RelativeLayout
        android:id="@+id/dialogHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_teal_rounded"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Información del Dispositivo"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"/>

        <ImageView
            android:id="@+id/btnDialogClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_constraintTop_toBottomOf="@id/dialogHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- SECCIÓN 1: INFORMACIÓN GENERAL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:text="Nombre" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogNombre" android:text="---" android:textColor="#212121" android:textSize="16sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>

                    <TextView android:text="Habitación" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogHabitacion" android:text="---" android:textColor="#212121" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>
                    
                    <TextView android:text="Tipo" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogTipo" android:text="---" android:textColor="#212121" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>

                    <TextView android:text="IP" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogIp" android:text="---" android:textColor="#212121" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>
                    
                    <TextView android:text="Firmware" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogFirmware" android:text="---" android:textColor="#212121" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>

                    <TextView android:text="RSSI" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogRssi" android:text="---" android:textColor="#212121" android:textSize="15sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="16dp" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:baselineAligned="false">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:text="Estado red" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                                <com.google.android.material.card.MaterialCardView android:id="@+id/statusDotInfo" android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="6dp" app:cardBackgroundColor="#6F7EA8" app:cardCornerRadius="4dp" app:cardElevation="0dp" app:strokeWidth="0dp" />
                                <TextView android:id="@+id/tvDialogStatusRed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Desconectado" android:textColor="#6F7EA8" android:textSize="14sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                        
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:text="Estado" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvDialogEstadoEncendido" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#212121" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>

                    <TextView android:text="Última conexión" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogUltimaConexion" android:text="---" android:textColor="#212121" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:layout_marginBottom="8dp"/>
                    
                    <TextView android:text="Tiempo activo" android:textColor="#757575" android:textSize="13sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvDialogTiempoActivo" android:text="---" android:textColor="#212121" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 2: CONSUMO ELÉCTRICO -->
            <TextView
                android:id="@+id/tvConsumoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consumo eléctrico"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvConsumoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginBottom="12dp">

                        <!-- Voltaje -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_voltage"
                                app:tint="#757575" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voltaje" android:textColor="#757575" android:textSize="12sp" />
                            <TextView android:id="@+id/tvDialogVoltaje" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/teal_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Corriente -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_current"
                                app:tint="#757575" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Corriente" android:textColor="#757575" android:textSize="12sp" />
                            <TextView android:id="@+id/tvDialogCorriente" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/teal_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Potencia -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_power_2"
                                app:tint="#757575" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Potencia" android:textColor="#757575" android:textSize="12sp" />
                            <TextView android:id="@+id/tvDialogPotencia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/teal_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Consumo hoy -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_power_2"
                                app:tint="#757575" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Consumo hoy" android:textColor="#757575" android:textSize="12sp" />
                            <TextView android:id="@+id/tvDialogConsumoHoy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/teal_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Consumo total -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/ic_power_2"
                                app:tint="#757575" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Consumo total" android:textColor="#757575" android:textSize="12sp" />
                            <TextView android:id="@+id/tvDialogEnergia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/teal_primary" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECCIÓN 3: HISTORIALES -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historial de consumo"
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogHistorialConsumo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:maxLines="5"
                        android:text="Cargando historial de consumo..."
                        android:textColor="#424242"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historial reciente (socket)"
                        android:textColor="#757575"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDialogHistorial"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:maxLines="6"
                        android:text="Cargando historial..."
                        android:textColor="#424242"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Overlay menu FAB -->
    <View
        android:id="@+id/fabOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"/>

    <!-- Mini FAB Consumo -->
    <LinearLayout
        android:id="@+id/llFabConsumo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="@+id/fabMain"
        app:layout_constraintBottom_toTopOf="@+id/llFabControles"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consumo detallado"
            android:textColor="@color/white"
            android:layout_marginEnd="16dp"
            android:textSize="14sp"
            android:textStyle="bold"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnDialogConsumo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@drawable/ic_clock"
            app:tint="@color/teal_primary"
            app:backgroundTint="@color/white"/>
    </LinearLayout>

    <!-- Mini FAB Controles -->
    <LinearLayout
        android:id="@+id/llFabControles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="@+id/fabMain"
        app:layout_constraintBottom_toTopOf="@+id/llFabEditar"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Controles"
            android:textColor="@color/white"
            android:layout_marginEnd="16dp"
            android:textSize="14sp"
            android:textStyle="bold"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnDialogControles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@drawable/ic_power"
            app:tint="@color/teal_primary"
            app:backgroundTint="@color/white"/>
    </LinearLayout>

    <!-- Mini FAB Editar -->
    <LinearLayout
        android:id="@+id/llFabEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="@+id/fabMain"
        app:layout_constraintBottom_toTopOf="@+id/fabMain"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar"
            android:textColor="@color/white"
            android:layout_marginEnd="16dp"
            android:textSize="14sp"
            android:textStyle="bold"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnDialogEditar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            android:src="@drawable/pencil"
            app:tint="@color/teal_primary"
            app:backgroundTint="@color/white"/>
    </LinearLayout>

    <!-- FAB Principal -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:elevation="6dp"
        android:src="@drawable/settings_filled"
        app:tint="@color/white"
        app:backgroundTint="@color/teal_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>