<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivActionIllustration"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_manordomo_sin_fondo"
            app:tint="@color/teal_primary"
            android:alpha="0.85"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué control deseas aplicar?"
            android:textColor="#073F4C"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona la instrucción que el ESP32 enviará al dispositivo al reconocer tu secuencia."
            android:textColor="#6F7E8E"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="20dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEncender"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:id="@+id/ivIconEncender"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_idle_low_battery"
                    app:tint="#073F4C"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/tvEncenderText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Encender"
                    android:textColor="#073F4C"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardApagar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:id="@+id/ivIconApagar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#073F4C"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/tvApagarText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Apagar"
                    android:textColor="#073F4C"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAlternar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:id="@+id/ivIconAlternar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/stat_notify_sync"
                    app:tint="#073F4C"
                    android:layout_marginEnd="16dp"/>

                <TextView
                    android:id="@+id/tvAlternarText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alternar Estado"
                    android:textColor="#073F4C"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
