<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5F3"> <TextView
    android:id="@+id/tvTituloGesto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Capturar acción"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textColor="#002D40"
    android:layout_marginTop="32dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvInstrucciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ejecuta el gesto para configurar el dispositivo. Asegúrate de que tu torso y manos estén dentro del encuadre."
        android:textAlignment="center"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloGesto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvInstrucciones"
        app:layout_constraintBottom_toTopOf="@id/btnIniciarContador"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/flContadorCircular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="invisible">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/pbContadorCircular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:progress="0"
                app:indicatorColor="#4CAF50"
                app:trackColor="#33000000"
                app:indicatorSize="160dp"
                app:trackThickness="12dp"
                app:indicatorDirectionCircular="clockwise" />

            <TextView
                android:id="@+id/tvContador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=""
                android:textSize="80sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"/>
        </FrameLayout>

        <ProgressBar
            android:id="@+id/pbContadorLineal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="0dp"
            android:progressDrawable="@drawable/progress_bar_custom"
            android:max="3000"
            android:progress="0"
            android:visibility="invisible"/>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnIniciarContador"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Iniciar Captura"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>