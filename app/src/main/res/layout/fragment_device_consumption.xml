<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FFFF">

    <!-- CABECERA AZUL (Con padding superior adaptativo para la barra de estado) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/teal_primary"
        app:cardCornerRadius="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnConsumptionClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/arrow_left"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvConsumptionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consumo Histórico"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnConsumptionClose"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnConsumptionClose" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- CONTENIDO PRINCIPAL SCROLLABLE -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- SELECTOR DE GRANULARIDAD -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGranularidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnDia"
                app:strokeColor="#E0E0E0">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDia"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Por Día"
                    android:textAllCaps="false"
                    android:textColor="@color/teal_primary"
                    app:rippleColor="#1A009688" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMes"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Por Mes"
                    android:textAllCaps="false"
                    android:textColor="@color/teal_primary"
                    app:rippleColor="#1A009688" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnVivo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="En Vivo"
                    android:textAllCaps="false"
                    android:textColor="@color/teal_primary"
                    app:rippleColor="#1A009688" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- RANGO DE FECHAS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRangoFechas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDesde"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Desde: ..."
                        android:textColor="#616161"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:icon="@android:drawable/ic_menu_today"
                        app:iconTint="@color/teal_primary" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="#E0E0E0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHasta"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Hasta: ..."
                        android:textColor="#616161"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:icon="@android:drawable/ic_menu_today"
                        app:iconTint="@color/teal_primary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:id="@+id/progressConsumo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:indeterminateTint="@color/teal_primary"
                android:visibility="gone" />

            <!-- BLOQUE 1: POTENCIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Potencia Promedio (W)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartPotencia"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="12dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- BLOQUE 2: ENERGÍA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Energía Consumida (Wh)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartEnergia"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="12dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- BLOQUE 3: CORRIENTE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Corriente Promedio (A)"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#757575"
                android:textAllCaps="true"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartCorriente"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="12dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>