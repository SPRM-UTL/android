<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- CABECERA PRINCIPAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_teal_rounded"
        android:paddingTop="36dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnConsumptionClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/arrow_left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvDeviceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="Consumo Histórico"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnConsumptionClose"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnConsumptionClose"
            app:layout_constraintTop_toTopOf="@id/btnConsumptionClose" />

        <!-- Total Consumido -->
        <TextView
            android:id="@+id/tvTotalConsumption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="0.00 kWh"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnConsumptionClose" />

        <!-- Costo Estimado -->
        <TextView
            android:id="@+id/tvEstimatedCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="6dp"
            android:text="≈ $0.00 MXN"
            android:textColor="#E0F2F1"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/tvTotalConsumption"
            app:layout_constraintStart_toEndOf="@id/tvTotalConsumption" />

        <!-- Comparación (Simulada si no hay datos) o Estado -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTotalConsumption">

            <ImageView
                android:id="@+id/ivTrend"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_current"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvTrendText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Analizando datos del período..."
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Consumo Actual -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLiveConsumption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            app:cardBackgroundColor="#F0F9F8"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="@id/tvTotalConsumption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTotalConsumption">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AHORA"
                    android:textSize="10sp"
                    android:textColor="@color/teal_primary"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvLiveConsumption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--- W"
                    android:textSize="14sp"
                    android:textColor="@color/teal_primary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTENIDO PRINCIPAL SCROLLABLE -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- SELECTOR DE PERÍODO -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@android:color/transparent"
                app:tabIndicator="@drawable/tab_indicator"
                app:tabIndicatorAnimationMode="elastic"
                app:tabIndicatorColor="@color/teal_primary"
                app:tabIndicatorGravity="center"
                app:tabIndicatorHeight="36dp"
                app:tabIndicatorFullWidth="true"
                app:tabMode="scrollable"
                app:tabRippleColor="@null"
                app:tabSelectedTextColor="@color/white"
                app:tabTextAppearance="@style/TextAppearance.AppCompat.Medium"
                app:tabTextColor="#6F7E8E">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy" />
                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semana" />
                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mes" />
                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Año" />
            </com.google.android.material.tabs.TabLayout>

            <!-- SKELETON LOADER -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerConsumo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:visibility="gone"
                app:shimmer_auto_start="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Chart Skeleton -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_skeleton" />

                    <!-- Desglose Header Skeleton -->
                    <View
                        android:layout_width="150dp"
                        android:layout_height="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_skeleton" />

                    <!-- Items Skeleton -->
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_skeleton" android:layout_marginBottom="8dp"/>
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_skeleton" android:layout_marginBottom="8dp"/>
                    <View android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_skeleton" android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- GRÁFICA PRINCIPAL -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartPrincipal"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="32dp"/>

            <!-- DESGLOSE DE PERÍODO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desglose del período"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDesglose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_consumo_punto"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_menu_share"
        app:tint="@color/white"
        app:backgroundTint="@color/teal_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
