<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FBFD"
    tools:context=".LugaresActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/arrow_left"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#073F4C" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mis Lugares"
            android:textColor="#073F4C"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvCasasTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Mis Casas"
        android:textColor="#073F4C"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddCasa"
        style="@style/Widget.Material3.Button.TextButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Nueva Casa"
        android:textColor="@color/teal_primary"
        app:icon="@drawable/plus"
        app:iconTint="@color/teal_primary"
        app:layout_constraintBottom_toBottomOf="@id/tvCasasTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvCasasTitle" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutCasas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="24dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/tvCasasTitle"
        app:tabIndicatorColor="@color/teal_primary"
        app:tabIndicatorHeight="3dp"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@color/teal_primary"
        app:tabTextAppearance="@style/TextAppearance.AppCompat.Medium" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutCasaActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeColor="#F0F3F7"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutCasas">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditCasa"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Editar Nombre"
                android:textColor="#6F7E8E"
                app:icon="@drawable/pencil"
                app:iconTint="#6F7E8E" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#E0E0E0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteCasa"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eliminar Casa"
                android:textColor="#E53935"
                app:icon="@drawable/x"
                app:iconTint="#E53935" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvHabitacionesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Habitaciones"
        android:textColor="#073F4C"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCasaActions" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddHabitacion"
        style="@style/Widget.Material3.Button.TextButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Agregar"
        android:textColor="@color/teal_primary"
        app:icon="@drawable/plus"
        app:iconTint="@color/teal_primary"
        app:layout_constraintBottom_toBottomOf="@id/tvHabitacionesTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvHabitacionesTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHabitaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHabitacionesTitle"
        tools:listitem="@layout/item_habitacion_edit" />

</androidx.constraintlayout.widget.ConstraintLayout>
