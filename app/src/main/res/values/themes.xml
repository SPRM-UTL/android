<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Android" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorSecondary">@color/teal_medium</item>
        <item name="android:statusBarColor">@color/teal_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textCursorDrawable">@drawable/cursor_custom</item>
        <item name="colorError">@color/red</item>
    </style>

    <style name="Theme.Android" parent="Base.Theme.Android" />

    <style name="Theme.AnimatedSplash.MySplash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="postSplashScreenTheme">@style/Theme.Android</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/avd_manordomo</item>
        <item name="windowSplashScreenAnimationDuration">2300</item>
    </style>

    <style name="EsquinasSuperioresRedondeadas"
        parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="CircleImage"
        parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.Custom.BottomAppBar" parent="Widget.Material3.BottomAppBar">
        <item name="backgroundTint">@color/black</item>
        <item name="fabCradleMargin">8dp</item>
        <item name="fabCradleRoundedCornerRadius">28dp</item>
        <item name="fabCradleVerticalOffset">6dp</item>
    </style>

</resources>